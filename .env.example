# MongoDB (required for live data after turning off demo in Settings)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/daily-scheduler?retryWrites=true&w=majority

# Optional — force demo on/off server-wide (default: demo ON in app Settings)
# USE_DEMO_DATA=true
# USE_DEMO_DATA=false

# Cloudinary — optional until you add file uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
